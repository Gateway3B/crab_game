{
    "scripts": {
        "run": "cargo run",
        "run:wasm": "cargo run --target wasm32-unknown-unknown",
        "build": "cargo build --release --target wasm32-unknown-unknown ",
        "build:prod": "wasm-bindgen --no-typescript --target web --out-dir ./out/ --out-name \"CrabGame\" ./target/wasm32-unknown-unknown/release/crab_game.wasm",
        "build:all": "npm run build && npm run build:prod",
        "docker:build": "docker build -t hl-docker-registry.g3tech.net/crab-game:latest .",
        "docker:push": "docker push hl-docker-registry.g3tech.net/crab-game:latest"
    }
}